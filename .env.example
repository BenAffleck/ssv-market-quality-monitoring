# --- Database (TimescaleDB / Postgres) ---
POSTGRES_USER=ssv
POSTGRES_PASSWORD=change_me_local_only
POSTGRES_DB=ssv_mqm
# DSN used by the Python services. Inside docker-compose the host is "timescaledb".
DATABASE_URL=postgresql://ssv:change_me_local_only@timescaledb:5432/ssv_mqm

# --- App config ---
# Optional: override the path to config.yaml.
SSV_MQM_CONFIG=/app/config/config.yaml
# Optional: log level (debug, info, warning, error).
LOG_LEVEL=info

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# --- Read-only posture ---
# This system uses PUBLIC market-data feeds only. No trade- or withdrawal-enabled
# API keys are required or supported. KuCoin's public WebSocket token is fetched
# automatically by CCXT Pro without authentication. Do NOT add trading credentials.
